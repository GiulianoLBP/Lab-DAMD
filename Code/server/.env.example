# Modelo de configuração — copie para .env e ajuste se necessário:
#   cp .env.example .env          (Linux/macOS)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# EVENT_BUS
#   rabbitmq  -> broker real e padrão da aplicação.
#   in_memory -> alternativa explícita APENAS para testes unitários; exige
#                RUN_CONSUMER_IN_PROCESS=true se o bootstrap do Flask for usado.
#
# RABBITMQ_HOST / RABBITMQ_PORT / RABBITMQ_USER / RABBITMQ_PASS
#   -> configuram o RabbitMQ. Os valores padrão apontam para localhost.
#
# Alternativa: usar uma URL única AMQP no lugar de HOST/PORT/USER/PASS
#   RABBITMQ_URL=amqp://guest:guest@localhost:5672/
#
# RUN_CONSUMER_IN_PROCESS (padrão: false)
#   false -> backend é PRODUTOR PURO; o consumo fica por conta do
#            consumer_worker.py (processo separado, ciclo de vida independente).
#   true  -> o backend também consome (thread daemon interna) — conveniência local.

EVENT_BUS=rabbitmq
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RUN_CONSUMER_IN_PROCESS=false
FASTDELIVERY_API_HOST=0.0.0.0
FASTDELIVERY_API_PORT=5055
FASTDELIVERY_API_PUBLIC_URL=http://localhost:5055

# Se a porta 5672 estiver reservada no Windows, use estas duas linhas:
# RABBITMQ_HOST_PORT=5679
# RABBITMQ_PORT=5679
