          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "[\n  {\n    \"entrega_id\": 4,\n    \"mensagem\": \"Nova entrega criada: Pacote teste\",\n    \"payload\": {\n      \"id\": 4,\n      \"descricao\": \"Pacote teste\",\n      \"origem\": \"Rua A\",\n      \"destino\": \"Rua B\",\n      \"status\": \"pendente\",\n      \"cliente_id\": \"cliente-123\",\n      \"criado_em\": \"2026-05-22T22:29:31\",\n      \"atualizado_em\": \"2026-05-22T22:29:31\"\n    },\n    \"processado_em\": \"2026-05-22T22:29:31\",\n    \"tipo\": \"entrega.criada\"\n  }\n]"
        }
      ]
    }
  ]
